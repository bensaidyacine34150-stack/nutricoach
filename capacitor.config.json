{
  "appId": "com.yacine.nutricoach",
  "appName": "NutriCoach AI",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "allowNavigation": [
      "api.anthropic.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com"
    ]
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#050b14",
    "limitsNavigationsToAppBoundDomains": false,
    "preferredContentMode": "mobile",
    "scheme": "nutricoach",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#050b14",
      "iosSpinnerStyle": "large",
      "spinnerColor": "#c8f135",
      "showSpinner": true,
      "splashFullScreen": true,
      "splashImmersive": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#050b14"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}
